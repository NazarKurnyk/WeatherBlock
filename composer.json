{
	"name": "nazar-kurnyk/weather-block",
	"description": "WordPress Gutenberg block combining post cards with OpenWeatherMap weather data.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcsstandards/phpcsutils": "^1.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"WeatherBlock\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"WeatherBlock\\Tests\\": "tests/php/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-text",
		"lint": "phpcs",
		"lint:fix": "phpcbf"
	}
}
